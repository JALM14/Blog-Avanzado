<%= form_with(model: post, local: true) do |form| %>
  <% if post.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <h2><%= pluralize(post.errors.count, "error") %> impidieron guardar esta publicación:</h2>
      <ul class="list-disc ml-6">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :title, class: "block font-bold" %>
    <%= form.text_field :title, class: "border rounded w-full p-2" %>
  </div>

  <div class="mb-4">
    <%= form.label :content, class: "block font-bold" %>
    <%= form.text_area :content, rows: 5, class: "border rounded w-full p-2" %>
  </div>

  <div>
    <%= form.submit class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
<% end %>
